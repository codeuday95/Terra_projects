// main.tf orchestrates all infrastructure components\n\nprovider "aws" {\n  region = "us-west-2"\n}\n\nresource "aws_s3_bucket" "my_bucket" {\n  bucket = "my-unique-bucket-name"\n  acl    = "private"\n}\n\nresource "aws_ec2_instance" "web_server" {\n  ami           = "ami-12345678"\n  instance_type = "t2.micro"\n}\n\noutput "bucket_name" {\n  value = aws_s3_bucket.my_bucket.bucket\n}\noutput "instance_id" {\n  value = aws_ec2_instance.web_server.id\n}\n